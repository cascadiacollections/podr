{
	"name": "podr - Node.js",
	"image": "mcr.microsoft.com/devcontainers/javascript-node:1-22-bookworm",
	"customizations": {
		"vscode": {
			"settings": {
				"editor.formatOnSave": true,
				"editor.codeActionsOnSave": {
					"source.fixAll.eslint": "explicit"
				},
				"editor.defaultFormatter": "esbenp.prettier-vscode",
				"typescript.preferences.importModuleSpecifier": "relative",
				"npm.packageManager": "yarn",
				"terminal.integrated.profiles.linux": {
					"bash": {
						"path": "/bin/bash"
					}
				}
			},
			"extensions": [
				"dbaeumer.vscode-eslint",
				"esbenp.prettier-vscode",
				"editorconfig.editorconfig",
				"ms-vscode.vscode-typescript-next",
				"orta.vscode-jest",
				"ms-vscode.vscode-json",
				"bradlc.vscode-tailwindcss",
				"ms-vscode.vscode-css-peek",
				"formulahendry.auto-rename-tag",
				"christian-kohler.path-intellisense",
				"ms-vscode.vscode-scss",
				"github.copilot",
				"github.copilot-chat",
				"github.vscode-pull-request-github"
			]
		}
	},
	"features": {
		"ghcr.io/devcontainers/features/common-utils:2": {},
		"ghcr.io/devcontainers/features/github-cli:1": {},
		"ghcr.io/devcontainers/features/git-lfs:1": {},
		"ghcr.io/devcontainers/features/node:1": {
			"nodeGypDependencies": true,
			"installYarnUsingApt": true,
			"version": "24"
		}
	},
	"mounts": [
		"source=podr-yarn-cache,target=/home/node/.cache/yarn,type=volume",
		"source=podr-npm-cache,target=/home/node/.npm,type=volume"
	],
	"onCreateCommand": ".devcontainer/on-create.sh",
	"postCreateCommand": ".devcontainer/post-create.sh",
	"updateContentCommand": ".devcontainer/update-content.sh",
	"postStartCommand": ".devcontainer/post-start.sh",
	"initializeCommand": "echo '🔧 Initializing Podr development environment...'",
	"remoteUser": "node",
	"containerEnv": {
		"PATH": "${containerEnv:PATH}:${localEnv:HOME}/.local/bin",
		"YARN_CACHE_FOLDER": "/home/node/.cache/yarn",
		"DEBIAN_FRONTEND": "noninteractive"
	}
}
